        },
        "url": {
          "raw": "http://localhost:3022/auth/register/request-code",
          "protocol": "http",
          "host": ["localhost"],
          "port": "3022",
          "path": ["auth", "register", "request-code"]
        },
        "description": "Primer paso del flujo de registro con verificación por email. Envía un código de 6 dígitos al correo del usuario.\n\n**Campos requeridos:**\n- `email`: Email válido del usuario\n- `password`: Mínimo 6 caracteres\n- `name`: Nombre completo del usuario\n\n**Respuesta exitosa:**\n```json\n{\n  \"message\": \"Código de verificación enviado al correo electrónico\"\n}\n```\n\n**Nota:** El código expira en 15 minutos."
      },
      "response": [
        {
          "name": "Ejemplo de respuesta exitosa",
          "originalRequest": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usuario@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Juan Pérez\"\n}"
            },
            "url": {
              "raw": "http://localhost:3022/auth/register/request-code",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3022",
              "path": ["auth", "register", "request-code"]
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "header": [
            {
              "key": "Content-Type",
              "value": "application/json"
            }
