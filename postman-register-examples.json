        }
      ]
    },
    {
      "name": "Registro con Verificación - Paso 1: Solicitar Código",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
